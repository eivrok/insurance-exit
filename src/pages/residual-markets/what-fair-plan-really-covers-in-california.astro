    <thead>
      <tr>
        <th>Coverage type</th>
        <th>Basic FAIR Plan policy</th>
        <th>Comprehensive FAIR Plan policy</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Dwelling (structure)</td>
        <td>Yes — up to policy limit</td>
        <td>Yes — up to policy limit</td>
      </tr>
      <tr>
        <td>Other structures</td>
        <td>Limited</td>
        <td>Yes</td>
      </tr>
      <tr>
        <td>Personal property (contents)</td>
        <td>Optional add-on only</td>
        <td>Yes — included</td>
      </tr>
      <tr>

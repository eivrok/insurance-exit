---
import Disclaimer from '@components/Disclaimer.astro';
import Nav from '@components/Nav.astro';
import Analytics from '@components/Analytics.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Page Not Found | InsuranceExit.org</title>
  <link rel="preload" href="/fonts/libre-franklin-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/source-serif-4-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <Analytics />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <Nav />

  <main id="main-content">
    <Disclaimer />
    <article style="max-width: 760px; margin: 4rem auto; padding: 0 1.5rem;">
      <h1>Page not found</h1>
      <p>That page doesn't exist or may have moved. Use the navigation above, or start with one of these:</p>
      <ul>
        <li><a href="/non-renewed/what-a-non-renewal-letter-actually-means/">What a non-renewal letter actually means</a></li>
        <li><a href="/non-renewed/your-30-60-90-day-decision-tree/">Your 30-60-90 day decision tree</a></li>
        <li><a href="/is-my-zip-next/">Is my ZIP next? — State pages</a></li>
        <li><a href="/residual-markets/what-fair-plan-really-covers-in-california/">What FAIR Plan really covers in California</a></li>
        <li><a href="/glossary/">Glossary of insurance terms</a></li>
      </ul>
    </article>
    <footer class="article-footer">
      <Disclaimer />
    </footer>
  </main>

  <footer class="site-footer">
    <p>InsuranceExit.org — General information only. Not legal, financial, or insurance advice. | <a href="/about/">About</a> | <a href="/contact/">Contact</a> | <a href="/glossary/">Glossary</a></p>
  </footer>
</body>
</html>

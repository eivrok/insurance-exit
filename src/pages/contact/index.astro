---
import Disclaimer from '@components/Disclaimer.astro';
import Search from '@components/Search.astro';
import Analytics from '@components/Analytics.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact — InsuranceExit.org</title>
  <meta name="description" content="Get in touch with InsuranceExit.org about questions or feedback." />
  <link rel="canonical" href="https://insuranceexit.org/contact/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Contact — InsuranceExit.org" />
  <meta property="og:description" content="Get in touch with InsuranceExit.org about questions or feedback." />
  <meta property="og:url" content="https://insuranceexit.org/contact/" />
  <meta property="og:site_name" content="InsuranceExit.org" />
  <meta property="og:image" content="https://insuranceexit.org/og-default.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="InsuranceExit.org — plain-English help when your home insurance is non-renewed" />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Contact — InsuranceExit.org" />
  <meta name="twitter:description" content="Get in touch with InsuranceExit.org about questions or feedback." />
  <meta name="twitter:image" content="https://insuranceexit.org/og-default.png" />
  <meta name="twitter:image:alt" content="InsuranceExit.org — plain-English help when your home insurance is non-renewed" />
  <link rel="preload" href="/fonts/libre-franklin-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/source-serif-4-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href="/styles/global.css" />
  <Analytics />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <header>
    <nav>
      <a href="/" class="site-name" style="display: flex; align-items: center; gap: 0.5rem;">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;">
          <path d="M3 10l9-9 9 9v11a2 2 0 01-2 2H5a2 2 0 01-2-2V10z" />
          <path d="M9 21v-7h6v7" />
        </svg>
        InsuranceExit.org
      </a>
      <ul>
        <li><a href="/non-renewed/">I Just Got Non-Renewed</a></li>
        <li><a href="/is-my-zip-next/">Is My ZIP Next</a></li>
        <li><a href="/fortifying-vs-selling/">Fortifying vs. Selling</a></li>
        <li><a href="/residual-markets/">Residual Markets</a></li>
      </ul>
      <Search />
    </nav>
  </header>

  <main id="main-content" data-pagefind-body style="max-width: 760px; margin: 0 auto; padding: 0 1.5rem;">
    <Disclaimer />

    <article style="margin: 2rem 0;">
      <h1>Contact</h1>
      <p>Questions or feedback about InsuranceExit.org? Use the form below to get in touch.</p>

      <form id="contact-form" name="contact" method="POST" action="https://formspree.io/f/mbdbenal" style="margin: 2rem 0;">
        <div style="margin-bottom: 1.25rem;">
          <label for="name" style="display: block; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; margin-bottom: 0.375rem; color: var(--text);">Name</label>
          <input type="text" id="name" name="name" required minlength="2" maxlength="100" placeholder="Your full name" style="width: 100%; padding: 0.75rem; font-family: var(--font-body); font-size: 1rem; border: 1px solid var(--border); border-radius: 4px; background: var(--bg); color: var(--text);" />
          <small style="display: block; font-family: var(--font-ui); font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">2–100 characters</small>
        </div>

        <div style="margin-bottom: 1.25rem;">
          <label for="email" style="display: block; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; margin-bottom: 0.375rem; color: var(--text);">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" style="width: 100%; padding: 0.75rem; font-family: var(--font-body); font-size: 1rem; border: 1px solid var(--border); border-radius: 4px; background: var(--bg); color: var(--text);" />
          <small style="display: block; font-family: var(--font-ui); font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">Valid email address required</small>
        </div>

        <div style="margin-bottom: 1.25rem;">
          <label for="message" style="display: block; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; margin-bottom: 0.375rem; color: var(--text);">Message</label>
          <textarea id="message" name="message" rows="6" required minlength="10" maxlength="5000" placeholder="Your message here..." style="width: 100%; padding: 0.75rem; font-family: var(--font-body); font-size: 1rem; border: 1px solid var(--border); border-radius: 4px; background: var(--bg); color: var(--text); resize: vertical;"></textarea>
          <small style="display: block; font-family: var(--font-ui); font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">10–5000 characters</small>
        </div>

        <button type="submit" class="btn-accent" style="padding: 0.75rem 1.5rem;">Send</button>
      </form>

      <div id="contact-success" style="display: none; margin: 2rem 0; padding: 1.25rem; border: 1px solid var(--border); border-radius: 4px; background: oklch(97% 0.02 145);">
        <p style="margin: 0; font-family: var(--font-ui); font-size: 1rem; font-weight: 600; color: var(--text);">Message received.</p>
        <p style="margin: 0.5rem 0 0; font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-muted);">Thanks for reaching out. We read every message and will respond if a reply is warranted.</p>
      </div>

      <div id="contact-error" style="display: none; margin: 2rem 0; padding: 1.25rem; border: 1px solid var(--border); border-radius: 4px; background: oklch(97% 0.03 25);">
        <p style="margin: 0; font-family: var(--font-ui); font-size: 1rem; font-weight: 600; color: var(--text);">Message didn't send.</p>
        <p style="margin: 0.5rem 0 0; font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-muted);">Something went wrong on our end. Please try again in a moment.</p>
      </div>

      <script>
        // Submit to Formspree via AJAX so the reader stays on insuranceexit.org
        // instead of landing on Formspree's generic thank-you page.
        const form = document.getElementById('contact-form');
        const successBox = document.getElementById('contact-success');
        const errorBox = document.getElementById('contact-error');

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          const submitBtn = form.querySelector('button[type="submit"]');
          submitBtn.disabled = true;
          errorBox.style.display = 'none';

          try {
            const res = await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { Accept: 'application/json' },
            });
            if (res.ok) {
              form.style.display = 'none';
              successBox.style.display = 'block';
            } else {
              // Formspree returned a non-2xx (validation, rate limit, etc.)
              submitBtn.disabled = false;
              errorBox.style.display = 'block';
            }
          } catch (err) {
            // Network/transport failure — surface it, don't swallow.
            submitBtn.disabled = false;
            errorBox.style.display = 'block';
          }
        });
      </script>
    </article>

    <Disclaimer />
  </main>

  <footer class="site-footer">
    <p>InsuranceExit.org — General information only. Not legal, financial, or insurance advice. | <a href="/about/">About</a> | <a href="/contact/">Contact</a> | <a href="/glossary/">Glossary</a></p>
  </footer>
</body>
</html>

---
// Site search. Index is generated by Pagefind as a post-build step
// (`pagefind --site dist`, wired into `npm run build`). The client lazy-loads
// the Pagefind runtime from /pagefind/ on first open; in `astro dev` that path
// doesn't exist yet, so the import is guarded and search degrades to a no-op.
// Styles live in global.css (.search-*) because result rows are injected at
// runtime and Astro's scoped styles only attach to build-time elements.
---
<button type="button" class="search-trigger" aria-haspopup="dialog" aria-label="Search the site">
  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" />
  </svg>
  <span class="search-trigger-label">Search</span>
  <kbd class="search-trigger-kbd">Ctrl K</kbd>
</button>

<dialog class="search-dialog" aria-label="Search this site">
  <form class="search-box" role="search" onsubmit="return false">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" />
    </svg>
    <input type="search" class="search-input" placeholder="Search the guides — e.g. force-placed, FAIR Plan, Florida" autocomplete="off" autocapitalize="off" spellcheck="false" aria-label="Search query" aria-controls="search-results" />
    <button type="button" class="search-close" aria-label="Close search"><kbd>Esc</kbd></button>
  </form>
  <div id="search-results" class="search-results" role="listbox" aria-label="Search results"></div>
  <p class="search-state" aria-live="polite"></p>
</dialog>

<script>
  const trigger = document.querySelector<HTMLButtonElement>('.search-trigger');
  const dialog = document.querySelector<HTMLDialogElement>('.search-dialog');
  const input = document.querySelector<HTMLInputElement>('.search-input');
  const resultsEl = document.querySelector<HTMLDivElement>('#search-results');
  const stateEl = document.querySelector<HTMLParagraphElement>('.search-state');
  const closeBtn = document.querySelector<HTMLButtonElement>('.search-close');
  const kbdHint = document.querySelector<HTMLElement>('.search-trigger-kbd');

  // Default label is "Ctrl K"; show the Cmd glyph only on Apple platforms.
  const ua = navigator as Navigator & { userAgentData?: { platform?: string } };
  const isMac = /mac|iphone|ipad|ipod/i.test(ua.userAgentData?.platform || navigator.platform || navigator.userAgent);
  if (kbdHint && isMac) kbdHint.textContent = '⌘K';

  if (trigger && dialog && input && resultsEl && stateEl) {
    let pagefind: any = null;
    let loadFailed = false;

    async function ensurePagefind() {
      if (pagefind || loadFailed) return pagefind;
      try {
        // Held in a variable so Rollup can't statically resolve it — the path
        // is served from the static /pagefind/ output, generated post-build and
        // absent at build time.
        const runtimePath = '/pagefind/pagefind.js';
        pagefind = await import(/* @vite-ignore */ runtimePath);
        await pagefind.init();
      } catch {
        loadFailed = true;
        stateEl!.textContent = 'Search is unavailable in this preview. It works on the built site.';
      }
      return pagefind;
    }

    function open() {
      if (dialog!.open) return;
      dialog!.showModal();
      ensurePagefind();
      requestAnimationFrame(() => input!.focus());
    }
    function close() {
      if (dialog!.open) dialog!.close();
    }

    trigger.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    // Backdrop click (the click lands on the dialog element itself, not a child).
    dialog.addEventListener('click', (e) => { if (e.target === dialog) close(); });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        dialog!.open ? close() : open();
      }
    });

    function escapeHtml(s: string) {
      return s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));
    }

    let token = 0;
    input.addEventListener('input', async () => {
      const query = input!.value.trim();
      const mine = ++token;
      resultsEl!.innerHTML = '';
      if (!query) { stateEl!.textContent = ''; return; }
      const pf = await ensurePagefind();
      if (!pf || mine !== token) return;
      stateEl!.textContent = 'Searching…';
      const search = await pf.debouncedSearch(query);
      if (!search || mine !== token) return; // superseded by a newer keystroke
      const data = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));
      if (mine !== token) return;
      if (data.length === 0) {
        stateEl!.textContent = `No matches for “${query}”.`;
        return;
      }
      stateEl!.textContent = '';
      resultsEl!.innerHTML = data.map((d: any) => {
        const title = escapeHtml(d.meta?.title || d.url);
        return `<a class="search-hit" role="option" href="${d.url}">
          <span class="search-hit-title">${title}</span>
          <span class="search-hit-excerpt">${d.excerpt}</span>
        </a>`;
      }).join('');
    });
  }
</script>

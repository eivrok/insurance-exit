---
import Disclaimer from '@components/Disclaimer.astro';
import Nav from '@components/Nav.astro';
import Analytics from '@components/Analytics.astro';

interface Props {
  state: string;
  slug: string;
  lastUpdated: string;
  status?: 'draft' | 'published';
  // Current market stress for a homeowner seeking coverage now (not structural
  // hazard). Assign per docs/severity-rubric.md; review each stat-refresh.
  severity?: 'elevated' | 'high' | 'critical';
}

const { state, slug, lastUpdated, status = 'draft', severity } = Astro.props;

const severityLabel: Record<string, string> = {
  critical: 'Market Crisis',
  high: 'High Stress',
  elevated: 'Elevated Risk',
};
const title = `Insurance Crisis in ${state}`;
const description = `Homeowners insurance non-renewal trends, carriers leaving, residual market options, and hazards in ${state}.`;
const fullTitle = `${title} | InsuranceExit.org`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL('/og-default.png', Astro.site).href;
const ogImageAlt = 'InsuranceExit.org — plain-English help when your home insurance is non-renewed';

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://insuranceexit.org/" },
    { "@type": "ListItem", "position": 2, "name": "Is My ZIP Next", "item": "https://insuranceexit.org/is-my-zip-next/" },
    { "@type": "ListItem", "position": 3, "name": state, "item": canonicalURL },
  ]
});

// schema.org dates must be ISO 8601; the `lastUpdated` prop is a display
// string like "June 2026", so map it to "YYYY-MM" (valid partial ISO).
const months: Record<string, string> = {
  January: '01', February: '02', March: '03', April: '04', May: '05', June: '06',
  July: '07', August: '08', September: '09', October: '10', November: '11', December: '12',
};
const [monthName, year] = (lastUpdated || '').split(' ');
const isoModified = months[monthName] && year ? `${year}-${months[monthName]}` : undefined;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalURL,
  "mainEntityOfPage": canonicalURL,
  "image": ogImageURL,
  "inLanguage": "en-US",
  "author": { "@type": "Organization", "name": "InsuranceExit.org", "url": "https://insuranceexit.org" },
  "publisher": {
    "@type": "Organization",
    "name": "InsuranceExit.org",
    "url": "https://insuranceexit.org",
    "logo": { "@type": "ImageObject", "url": "https://insuranceexit.org/og-default.png" },
  },
  "datePublished": isoModified,
  "dateModified": isoModified,
});
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {status === 'draft' && <meta name="robots" content="noindex,nofollow" />}
  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="InsuranceExit.org" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <!-- Fonts -->
  <link rel="preload" href="/fonts/libre-franklin-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/source-serif-4-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href="/styles/global.css" />
  <!-- Structured data -->
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={articleSchema} />
  <Analytics />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <Nav active="is-my-zip-next" />

  <main id="main-content" data-pagefind-body>
    <div class="breadcrumb" data-pagefind-ignore>
      <a href="/">Home</a> &rsaquo;
      <a href="/is-my-zip-next/">Is My ZIP Next</a> &rsaquo;
      <span>{state}</span>
    </div>

    <Disclaimer />

    {status === 'draft' && (
      <div class="draft-banner">
        <strong>DRAFT — not for publication.</strong> This page is a structural stub. Content forthcoming.
      </div>
    )}

    <article>
      {severity && (
        <div class={`severity-badge severity-badge--${severity}`}>
          <span class="severity-glyph" aria-hidden="true"></span>
          {severityLabel[severity]}
        </div>
      )}
      <h1>{title}</h1>

      <slot name="tldr">
        {/* Summary slot — optional. Use "What you need to know:" as caption for clarity and accessibility. */}
      </slot>

      <h2 id="section-1">1. The one-paragraph summary</h2>
      <slot name="summary"><p><em>[Forthcoming — most recent state-of-the-market summary for {state}, dated.]</em></p></slot>

      <h2 id="section-2">2. Non-renewal and cancellation rates</h2>
      <slot name="nonrenewal-rates"><p><em>[Forthcoming — most recent NAIC and {state} DOI data, in table form, with dates.]</em></p></slot>

      <h2 id="section-3">3. Major carriers leaving, pausing, or shrinking</h2>
      <slot name="carriers"><p><em>[Forthcoming — table of carriers with announcement dates.]</em></p></slot>

      <h2 id="section-4">4. The residual market option in {state}</h2>
      <slot name="residual-market"><p><em>[Forthcoming — what it covers, what it doesn't, how to apply.]</em></p></slot>

      <h2 id="section-5">5. Top hazards driving the crisis</h2>
      <slot name="hazards"><p><em>[Forthcoming — wildfire / hurricane / hail / flood / freeze ranked for {state}.]</em></p></slot>

      <h2 id="section-6">6. What state regulators have done</h2>
      <slot name="regulators"><p><em>[Forthcoming — recent rate filings, moratoriums, market-stabilization laws.]</em></p></slot>

      <h2 id="section-7">7. Fortification programs available</h2>
      <slot name="fortification"><p><em>[Forthcoming — state grants, IBHS FORTIFIED uptake, mandated premium discounts.]</em></p></slot>

      <h2 id="section-8">8. What homeowners are reporting</h2>
      <slot name="homeowners-reporting"><p><em>[Forthcoming — sourced from public {state} DOI complaint data or news reporting.]</em></p></slot>

      <h2 id="section-9">9. Three things to do in the next 30 days</h2>
      <slot name="next-steps"><p><em>[Forthcoming — concrete, dated, plain-English steps.]</em></p></slot>

      <h2 id="section-10">10. Sources and date of last update</h2>
      <slot name="sources"><p><em>[Forthcoming — Treasury FIO January 2025 report, Senate Budget Committee December 2024 staff report, NAIC, {state} DOI, plus state-specific filings.]</em></p></slot>
    </article>

    <footer class="article-footer" data-pagefind-ignore>
      <p class="last-updated">Last updated: {lastUpdated}</p>

      {status === 'published' && (
        <div style="margin: 2rem 0; padding: 1.5rem; border: 1px solid var(--border); border-radius: 4px; background: var(--bg-subtle);">
          <p style="margin: 0 0 0.75rem; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 500; color: var(--text);">Was this helpful?</p>
          <button
            id="helpful-btn"
            type="button"
            class="btn-accent"
            style="padding: 0.5rem 1rem;"
          >
            👍 Yes, helpful
          </button>
          <span id="helpful-feedback" style="display: none; margin-left: 1rem; font-family: var(--font-ui); font-size: 0.875rem; color: var(--accent);">✓ Thanks for the feedback</span>
        </div>
      )}

      <!-- Hidden form for vote capture (submits to Formspree) -->
      <form name="votes" method="POST" action="https://formspree.io/f/xnjryebj" hidden style="display: none;">
        <input type="hidden" name="article" id="article-slug" value={slug} />
        <input type="hidden" name="helpful" value="yes" />
      </form>

      <script>
        document.getElementById('helpful-btn')?.addEventListener('click', async function(event) {
          event.preventDefault();
          const form = document.querySelector('form[name="votes"]');
          const btn = document.getElementById('helpful-btn');
          const feedback = document.getElementById('helpful-feedback');

          // Acknowledge immediately: hides the button (preventing a double-vote
          // while the request is in flight) and shows the thanks span.
          btn.style.display = 'none';
          feedback.style.display = 'inline';

          // AJAX submit so the reader stays on the article — no navigation to
          // Formspree's thank-you page. Fire-and-forget: a thumbs-up is
          // non-critical, so a transport failure needs no user-facing handling.
          try {
            await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { Accept: 'application/json' },
            });
          } catch (err) {
            // Intentionally non-fatal — see above.
          }
        });
      </script>

      <Disclaimer />
    </footer>
  </main>

  <footer class="site-footer">
    <p>InsuranceExit.org — General information only. Not legal, financial, or insurance advice. | <a href="/about/">About</a> | <a href="/contact/">Contact</a> | <a href="/glossary/">Glossary</a></p>
  </footer>
</body>
</html>

---
import Disclaimer from '@components/Disclaimer.astro';

interface Props {
  title: string;
  description: string;
  pillar: 'non-renewed' | 'is-my-zip-next' | 'fortifying-vs-selling' | 'residual-markets';
  lastUpdated: string;
}

const { title, description, pillar, lastUpdated } = Astro.props;

const pillarLabels: Record<string, string> = {
  'non-renewed': 'I Just Got Non-Renewed',
  'is-my-zip-next': 'Is My ZIP Next',
  'fortifying-vs-selling': 'Fortifying vs. Selling',
  'residual-markets': 'Residual Markets',
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const fullTitle = `${title} | InsuranceExit.us`;

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://insuranceexit.us/" },
    { "@type": "ListItem", "position": 2, "name": pillarLabels[pillar], "item": `https://insuranceexit.us/${pillar}/` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL },
  ]
});

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalURL,
  "publisher": { "@type": "Organization", "name": "InsuranceExit.us", "url": "https://insuranceexit.us" },
  "dateModified": lastUpdated,
});
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="InsuranceExit.us" />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Lora:ital,wght@0,400;0,600;1,400&family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <!-- Structured data -->
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={articleSchema} />
</head>
<body>
  <header>
    <nav>
      <a href="/" class="site-name">InsuranceExit.us</a>
      <ul>
        <li><a href="/non-renewed/">I Just Got Non-Renewed</a></li>
        <li><a href="/is-my-zip-next/">Is My ZIP Next</a></li>
        <li><a href="/fortifying-vs-selling/">Fortifying vs. Selling</a></li>
        <li><a href="/residual-markets/">Residual Markets</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <div class="breadcrumb">
      <a href="/">Home</a> &rsaquo;
      <a href={`/${pillar}/`}>{pillarLabels[pillar]}</a>
    </div>

    <Disclaimer />

    <article>
      <h1>{title}</h1>
      <slot />
    </article>

    <footer class="article-footer">
      <p class="last-updated">Last updated: {lastUpdated}</p>
      <Disclaimer />
    </footer>
  </main>

  <footer class="site-footer">
    <p>InsuranceExit.us — General information only. Not legal, financial, or insurance advice. | <a href="/glossary/">Glossary</a></p>
  </footer>
</body>
</html>

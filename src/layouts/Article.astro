---
import Disclaimer from '@components/Disclaimer.astro';
import Nav from '@components/Nav.astro';
import Analytics from '@components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  pillar: 'non-renewed' | 'is-my-zip-next' | 'fortifying-vs-selling' | 'residual-markets';
  lastUpdated: string;
  // Optional SEO <title> override; visible H1 always stays `title`. Falls back
  // to `title` when unset, so already-search-strong headlines need no change.
  seoTitle?: string;
}

const { title, description, pillar, lastUpdated, seoTitle } = Astro.props;

const pillarLabels: Record<string, string> = {
  'non-renewed': 'I Just Got Non-Renewed',
  'is-my-zip-next': 'Is My ZIP Next',
  'fortifying-vs-selling': 'Fortifying vs. Selling',
  'residual-markets': 'Residual Markets',
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const fullTitle = `${seoTitle ?? title} | InsuranceExit.org`;
const ogImageURL = new URL('/og-default.png', Astro.site).href;
const ogImageAlt = 'InsuranceExit.org — plain-English help when your home insurance is non-renewed';

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://insuranceexit.org/" },
    { "@type": "ListItem", "position": 2, "name": pillarLabels[pillar], "item": `https://insuranceexit.org/${pillar}/` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL },
  ]
});

// schema.org dates must be ISO 8601; the `lastUpdated` prop is a display
// string like "June 2026", so map it to "YYYY-MM" (valid partial ISO).
const months: Record<string, string> = {
  January: '01', February: '02', March: '03', April: '04', May: '05', June: '06',
  July: '07', August: '08', September: '09', October: '10', November: '11', December: '12',
};
const [monthName, year] = (lastUpdated || '').split(' ');
const isoModified = months[monthName] && year ? `${year}-${months[monthName]}` : undefined;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalURL,
  "mainEntityOfPage": canonicalURL,
  "image": ogImageURL,
  "inLanguage": "en-US",
  "author": { "@type": "Organization", "name": "InsuranceExit.org", "url": "https://insuranceexit.org" },
  "publisher": {
    "@type": "Organization",
    "name": "InsuranceExit.org",
    "url": "https://insuranceexit.org",
    "logo": { "@type": "ImageObject", "url": "https://insuranceexit.org/og-default.png" },
  },
  "datePublished": isoModified,
  "dateModified": isoModified,
});
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="InsuranceExit.org" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <!-- Fonts -->
  <link rel="preload" href="/fonts/libre-franklin-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/source-serif-4-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href="/styles/global.css" />
  <!-- Structured data -->
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={articleSchema} />
  <Analytics />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <Nav active={pillar} />

  <main id="main-content" data-pagefind-body>
    <div class="breadcrumb" data-pagefind-ignore>
      <a href="/">Home</a> &rsaquo;
      <a href={`/${pillar}/`}>{pillarLabels[pillar]}</a>
    </div>

    <Disclaimer />

    <article>
      <h1>{title}</h1>
      <slot />
    </article>

    <footer class="article-footer" data-pagefind-ignore>
      <p class="last-updated">Last updated: {lastUpdated}</p>
      <Disclaimer />
    </footer>
  </main>

  <footer class="site-footer">
    <p>InsuranceExit.org — General information only. Not legal, financial, or insurance advice. | <a href="/about/">About</a> | <a href="/contact/">Contact</a> | <a href="/glossary/">Glossary</a></p>
  </footer>
</body>
</html>

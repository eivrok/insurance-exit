---
import Disclaimer from '@components/Disclaimer.astro';
import Search from '@components/Search.astro';

interface Props {
  title: string;
  description: string;
  pillar: 'non-renewed' | 'is-my-zip-next' | 'fortifying-vs-selling' | 'residual-markets';
  lastUpdated: string;
}

const { title, description, pillar, lastUpdated } = Astro.props;

const pillarLabels: Record<string, string> = {
  'non-renewed': 'I Just Got Non-Renewed',
  'is-my-zip-next': 'Is My ZIP Next',
  'fortifying-vs-selling': 'Fortifying vs. Selling',
  'residual-markets': 'Residual Markets',
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const fullTitle = `${title} | InsuranceExit.org`;
const ogImageURL = new URL('/og-default.png', Astro.site).href;
const ogImageAlt = 'InsuranceExit.org — plain-English help when your home insurance is non-renewed';

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://insuranceexit.org/" },
    { "@type": "ListItem", "position": 2, "name": pillarLabels[pillar], "item": `https://insuranceexit.org/${pillar}/` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL },
  ]
});

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonicalURL,
  "publisher": { "@type": "Organization", "name": "InsuranceExit.org", "url": "https://insuranceexit.org" },
  "dateModified": lastUpdated,
});
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="InsuranceExit.org" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <!-- Fonts -->
  <link rel="preload" href="/fonts/libre-franklin-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/source-serif-4-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href="/styles/global.css" />
  <!-- Structured data -->
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={articleSchema} />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <header>
    <nav>
      <a href="/" class="site-name" style="display: flex; align-items: center; gap: 0.5rem;">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;">
          <path d="M3 10l9-9 9 9v11a2 2 0 01-2 2H5a2 2 0 01-2-2V10z" />
          <path d="M9 21v-7h6v7" />
        </svg>
        InsuranceExit.org
      </a>
      <ul>
        <li><a href="/non-renewed/" aria-current={pillar === 'non-renewed' ? 'page' : undefined}>I Just Got Non-Renewed</a></li>
        <li><a href="/is-my-zip-next/" aria-current={pillar === 'is-my-zip-next' ? 'page' : undefined}>Is My ZIP Next</a></li>
        <li><a href="/fortifying-vs-selling/" aria-current={pillar === 'fortifying-vs-selling' ? 'page' : undefined}>Fortifying vs. Selling</a></li>
        <li><a href="/residual-markets/" aria-current={pillar === 'residual-markets' ? 'page' : undefined}>Residual Markets</a></li>
      </ul>
      <Search />
    </nav>
  </header>

  <main id="main-content" data-pagefind-body>
    <div class="breadcrumb" data-pagefind-ignore>
      <a href="/">Home</a> &rsaquo;
      <a href={`/${pillar}/`}>{pillarLabels[pillar]}</a>
    </div>

    <Disclaimer />

    <article>
      <h1>{title}</h1>
      <slot />
    </article>

    <footer class="article-footer" data-pagefind-ignore>
      <p class="last-updated">Last updated: {lastUpdated}</p>
      <Disclaimer />
    </footer>
  </main>

  <footer class="site-footer">
    <p>InsuranceExit.org — General information only. Not legal, financial, or insurance advice. | <a href="/about/">About</a> | <a href="/contact/">Contact</a> | <a href="/glossary/">Glossary</a></p>
  </footer>
</body>
</html>

---
import Disclaimer from '@components/Disclaimer.astro';
import Nav from '@components/Nav.astro';
import Analytics from '@components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  intro: string;
}

const { title, description, intro } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const fullTitle = `${title} | InsuranceExit.org`;
const ogImageURL = new URL('/og-default.png', Astro.site).href;
const ogImageAlt = 'InsuranceExit.org — plain-English help when your home insurance is non-renewed';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="InsuranceExit.org" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <!-- Fonts -->
  <link rel="preload" href="/fonts/libre-franklin-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/source-serif-4-var-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href="/styles/global.css" />
  <Analytics />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <Nav />

  <main id="main-content" data-pagefind-body>
    <div class="breadcrumb" data-pagefind-ignore>
      <a href="/">Home</a>
    </div>

    <Disclaimer />

    <article>
      <h1 class="pillar-heading">{title}</h1>
      <p class="page-summary">{intro}</p>
      <slot />
    </article>

    <footer class="article-footer" data-pagefind-ignore>
      <Disclaimer />
    </footer>
  </main>

  <footer class="site-footer">
    <p>InsuranceExit.org — General information only. Not legal, financial, or insurance advice. | <a href="/about/">About</a> | <a href="/contact/">Contact</a> | <a href="/glossary/">Glossary</a></p>
  </footer>
</body>
</html>
